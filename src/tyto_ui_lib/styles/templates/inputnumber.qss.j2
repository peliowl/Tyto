/* ===== Disabled ===== */

TInputNumber[disabled="true"] {
    opacity: 0.5;
}

/* ===== Bordered false ===== */

TInputNumber[bordered="false"] {
    border: none;
}

/* ===== Round ===== */

TInputNumber[round="true"] QToolButton {
    border-radius: 50%;
}

/* ===== Status variants ===== */

TInputNumber[status="success"] QToolButton:hover {
    color: {{ colors.success }};
}

TInputNumber[status="warning"] QToolButton:hover {
    color: {{ colors.warning }};
}

TInputNumber[status="error"] QToolButton:hover {
    color: {{ colors.error }};
}

/* ===== Button placement: both ===== */

TInputNumber[buttonPlacement="both"] QToolButton#btn_minus {
    border: none;
}

TInputNumber[buttonPlacement="both"] QToolButton#btn_plus {
    border: none;
}

/* ===== Button placement: right (default) ===== */

TInputNumber[buttonPlacement="right"] QToolButton#btn_minus {
    border: none;
}

TInputNumber[buttonPlacement="right"] QToolButton#btn_plus {
    border: none;
}
