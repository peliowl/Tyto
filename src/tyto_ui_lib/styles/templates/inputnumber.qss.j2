{# inputnumber.qss.j2 — QSS template for TInputNumber component #}

/* ===== Base styles (border painted in paintEvent) ===== */

TInputNumber {
    background-color: transparent;
    border: none;
    padding: 0px;
    outline: none;
}

TInputNumber QLineEdit {
    background-color: transparent;
    color: {{ colors.text_primary }};
    border: none;
    border-radius: 0px;
    padding: 0px;
    padding-left: {{ spacing.small }}px;
    font-size: {{ font_sizes.medium }}px;
    selection-background-color: {{ colors.primary }};
    selection-color: {{ colors.white }};
}

TInputNumber QLineEdit:focus {
    border: none;
}

TInputNumber QLineEdit:hover {
    border: none;
}

TInputNumber QLineEdit:disabled {
    color: {{ colors.text_disabled }};
    background-color: transparent;
}

/* ===== Buttons ===== */

TInputNumber > QToolButton {
    background-color: transparent;
    color: {{ colors.text_primary }};
    border: none;
    font-size: {{ font_sizes.medium }}px;
    padding: 0px;
}

TInputNumber > QToolButton:hover {
    color: {{ colors.primary }};
}

TInputNumber > QToolButton:pressed {
    color: {{ colors.primary_pressed }};
}

TInputNumber > QToolButton:disabled {
    color: {{ colors.text_disabled }};
    background-color: transparent;
}

/* Action buttons (clear icon) */
TInputNumber > QToolButton#btn_clear {
    background-color: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
    color: {{ colors.text_secondary }};
}

TInputNumber > QToolButton#btn_clear:hover {
    color: {{ colors.text_primary }};
}

/* ===== Size: tiny ===== */

TInputNumber[inputNumberSize="tiny"] {
    min-height: {{ component_sizes.tiny.height }}px;
    max-height: {{ component_sizes.tiny.height }}px;
}

TInputNumber[inputNumberSize="tiny"] QLineEdit {
    min-height: {{ component_sizes.tiny.height }}px;
    max-height: {{ component_sizes.tiny.height }}px;
    font-size: {{ component_sizes.tiny.font_size }}px;
}

TInputNumber[inputNumberSize="tiny"] QToolButton#btn_minus,
TInputNumber[inputNumberSize="tiny"] QToolButton#btn_plus,
TInputNumber[inputNumberSize="tiny"] QToolButton#btn_clear {
    min-height: {{ component_sizes.tiny.height }}px;
    max-height: {{ component_sizes.tiny.height }}px;
    min-width: {{ component_sizes.tiny.icon_size }}px;
    max-width: {{ component_sizes.tiny.icon_size }}px;
    font-size: {{ component_sizes.tiny.icon_size }}px;
}

/* ===== Size: small ===== */

